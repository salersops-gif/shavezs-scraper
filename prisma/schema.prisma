generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  PENDING
  IN_PROGRESS
  PARTIAL
  COMPLETE
  FAILED
}

enum LeadQuality {
  COLD  // 0–39
  WARM  // 40–69
  HOT   // 70–100
}

enum SourceType {
  GOOGLE_MAPS
  DIRECTORY
  MANUAL
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  SUCCESS
  WARN
  ERROR
}

// ─────────────────────────────────────────────────────────────
// User — mirrors Supabase auth.users (public schema copy)
// ─────────────────────────────────────────────────────────────

model User {
  id         String      @id
  email      String      @unique
  created_at DateTime    @default(now()) @map("created_at")
  updated_at DateTime    @updatedAt      @map("updated_at")

  scrapeJobs ScrapeJob[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Lead
//
// Lead Score Calculation (0–100 points):
//   +20  Verified email (Bouncify status = "deliverable")
//   +15  Phone number found
//   +10  WhatsApp Business link detected on site
//   +10  "Manufacturing", "OEM", "Export" found in meta description
//   +10  Tech stack identified (Shopify, WordPress, etc.)
//   +10  Has website
//   + 5  Source is Google Maps (higher trust)
//   + 5  Full street address available
//
// Quality buckets:  COLD = 0–39 | WARM = 40–69 | HOT = 70–100
// ─────────────────────────────────────────────────────────────

model Lead {
  id                String           @id @default(cuid())
  company_name      String           @map("company_name")
  website           String?
  email             String?
  phone             String?

  location          String?
  address           String?
  city              String?
  country           String?

  industry          String?
  keyword           String?
  meta_description  String?          @map("meta_description")

  tech_stack        String[]         @map("tech_stack")

  lead_score        Int              @default(0)       @map("lead_score")
  lead_quality      LeadQuality      @default(COLD)    @map("lead_quality")
  enrichment_status EnrichmentStatus @default(PENDING) @map("enrichment_status")

  has_whats_app     Boolean          @default(false)   @map("has_whats_app")
  has_email         Boolean          @default(false)   @map("has_email")
  has_phone         Boolean          @default(false)   @map("has_phone")
  has_website       Boolean          @default(false)   @map("has_website")

  source_type       SourceType       @default(GOOGLE_MAPS) @map("source_type")
  source_url        String?          @map("source_url")

  notes             String?
  created_at        DateTime         @default(now()) @map("created_at")
  updated_at        DateTime         @updatedAt      @map("updated_at")

  scrape_job_id     String?          @map("scrape_job_id")
  scrapeJob         ScrapeJob?       @relation(fields: [scrape_job_id], references: [id])
  enrichmentLogs    EnrichmentLog[]
  techDetections    TechDetection[]
  emailVerification EmailVerification?

  @@map("leads")
}

// ─────────────────────────────────────────────────────────────
// ScrapeJob
// ─────────────────────────────────────────────────────────────

model ScrapeJob {
  id            String     @id @default(cuid())
  query         String
  niche         String
  location      String
  max_results   Int        @default(50)    @map("max_results")
  status        JobStatus  @default(PENDING)
  progress      Int        @default(0)
  total_found   Int        @default(0)     @map("total_found")
  error_message String?    @map("error_message")
  github_run_id String?    @map("github_run_id")
  github_run_url String?   @map("github_run_url")
  created_at    DateTime   @default(now()) @map("created_at")
  updated_at    DateTime   @updatedAt      @map("updated_at")
  completed_at  DateTime?  @map("completed_at")

  user_id       String?    @map("user_id")
  user          User?      @relation(fields: [user_id], references: [id])
  leads         Lead[]
  logs          JobLog[]

  @@map("scrape_jobs")
}

// ─────────────────────────────────────────────────────────────
// JobLog — powers the real-time Terminal Stream
// ─────────────────────────────────────────────────────────────

model JobLog {
  id         String     @id @default(cuid())
  job_id     String     @map("job_id")
  level      LogLevel   @default(INFO)
  message    String
  created_at DateTime   @default(now()) @map("created_at")

  job        ScrapeJob  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("job_logs")
}

// ─────────────────────────────────────────────────────────────
// EnrichmentLog
// ─────────────────────────────────────────────────────────────

model EnrichmentLog {
  id         String   @id @default(cuid())
  lead_id    String   @map("lead_id")
  step       String
  status     String
  message    String?
  data       Json?
  created_at DateTime @default(now()) @map("created_at")

  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("enrichment_logs")
}

// ─────────────────────────────────────────────────────────────
// TechDetection
// ─────────────────────────────────────────────────────────────

model TechDetection {
  id         String   @id @default(cuid())
  lead_id    String   @map("lead_id")
  technology String
  confidence String   @default("HIGH")
  evidence   String?
  created_at DateTime @default(now()) @map("created_at")

  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("tech_detections")
}

// ─────────────────────────────────────────────────────────────
// EmailVerification — Bouncify result (primary verifier)
// ─────────────────────────────────────────────────────────────

model EmailVerification {
  id          String   @id @default(cuid())
  lead_id     String   @unique @map("lead_id")
  email       String
  is_valid    Boolean? @map("is_valid")
  // Bouncify: "deliverable" | "undeliverable" | "risky" | "unknown"
  status      String?
  // Provider: "bouncify" | "myemailverifier"
  provider    String?
  verified_at DateTime @default(now()) @map("verified_at")

  lead        Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}
