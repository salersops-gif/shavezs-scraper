generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeTypes"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  PENDING
  IN_PROGRESS
  PARTIAL
  COMPLETE
  FAILED
}

enum LeadQuality {
  COLD
  WARM
  HOT
}

enum SourceType {
  GOOGLE_MAPS
  DIRECTORY
  MANUAL
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  SUCCESS
  WARN
  ERROR
}

// ─────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────

model User {
  id         String      @id @db.Uuid
  email      String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt      @map("updated_at")

  scrapeJobs ScrapeJob[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Lead
// Lead Score: +20 verified email, +15 phone, +10 whatsapp,
//   +10 keywords, +10 tech stack, +10 website, +5 maps, +5 address
// Quality: COLD 0–39 | WARM 40–69 | HOT 70–100
// ─────────────────────────────────────────────────────────────

model Lead {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName      String           @map("company_name")
  website          String?
  email            String?
  phone            String?
  location         String?
  address          String?
  city             String?
  country          String?
  industry         String?
  keyword          String?
  metaDescription  String?          @map("meta_description")
  techStack        String[]         @map("tech_stack")
  leadScore        Int              @default(0)           @map("lead_score")
  leadQuality      LeadQuality      @default(COLD)        @map("lead_quality")
  enrichmentStatus EnrichmentStatus @default(PENDING)     @map("enrichment_status")
  hasWhatsApp      Boolean          @default(false)       @map("has_whats_app")
  hasEmail         Boolean          @default(false)       @map("has_email")
  hasPhone         Boolean          @default(false)       @map("has_phone")
  hasWebsite       Boolean          @default(false)       @map("has_website")
  sourceType       SourceType       @default(GOOGLE_MAPS) @map("source_type")
  sourceUrl        String?          @map("source_url")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt      @map("updated_at")

  scrapeJobId      String?          @map("scrape_job_id") @db.Uuid
  scrapeJob        ScrapeJob?       @relation(fields: [scrapeJobId], references: [id])
  enrichmentLogs   EnrichmentLog[]
  techDetections   TechDetection[]
  emailVerification EmailVerification?

  @@map("leads")
}

// ─────────────────────────────────────────────────────────────
// ScrapeJob
// ─────────────────────────────────────────────────────────────

model ScrapeJob {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  query        String
  niche        String
  location     String
  maxResults   Int        @default(50)  @map("max_results")
  status       JobStatus  @default(PENDING)
  progress     Int        @default(0)
  totalFound   Int        @default(0)   @map("total_found")
  errorMessage String?    @map("error_message")
  githubRunId  String?    @map("github_run_id")
  githubRunUrl String?    @map("github_run_url")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")
  completedAt  DateTime?  @map("completed_at")

  userId       String?    @map("user_id") @db.Uuid
  user         User?      @relation(fields: [userId], references: [id])
  leads        Lead[]
  logs         JobLog[]

  @@map("scrape_jobs")
}

// ─────────────────────────────────────────────────────────────
// JobLog — real-time terminal stream
// ─────────────────────────────────────────────────────────────

model JobLog {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId     String     @map("job_id") @db.Uuid
  level     LogLevel   @default(INFO)
  message   String
  createdAt DateTime   @default(now()) @map("created_at")

  job       ScrapeJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_logs")
}

// ─────────────────────────────────────────────────────────────
// EnrichmentLog
// ─────────────────────────────────────────────────────────────

model EnrichmentLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  step      String
  status    String
  message   String?
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("enrichment_logs")
}

// ─────────────────────────────────────────────────────────────
// TechDetection
// ─────────────────────────────────────────────────────────────

model TechDetection {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  technology String
  confidence String   @default("HIGH")
  evidence   String?
  createdAt  DateTime @default(now()) @map("created_at")

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("tech_detections")
}

// ─────────────────────────────────────────────────────────────
// EmailVerification
// ─────────────────────────────────────────────────────────────

model EmailVerification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @unique @map("lead_id") @db.Uuid
  email      String
  isValid    Boolean? @map("is_valid")
  status     String?
  provider   String?
  verifiedAt DateTime @default(now()) @map("verified_at")

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}
